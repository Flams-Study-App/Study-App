# No database setup needed — Synapse stores data in local JSON files
# under server/data/, created automatically the first time you run the server.

# Random long random string used to sign JWT tokens (any string works, keep it secret)
JWT_SECRET=replace_this_with_a_long_random_string

# Google Gemini API key (Optional/unused in offline mock mode)
# GEMINI_API_KEY=

# Port the backend runs on
PORT=5000

# Comma-separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:5173
